[Unit]
Description=Searcher MCP FastAPI Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/repo/searcher
EnvironmentFile=/opt/repo/.env
ExecStart=/opt/repo/searcher/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000 --root-path ${SEARCHER_ROOT_PATH:-}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
