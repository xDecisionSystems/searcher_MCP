# Shared environment file for all searcher-stack services.
# Copy this to .env (or .env.dev for local testing) and fill in your keys.
# This file is uploaded to all services during deployment.

# ── Scholarly search providers ────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
SERPAPI_API_KEY=
IEEE_XPLORE_API_KEY=
WEB_OF_SCIENCE_API_KEY=
ELSEVIER_API_KEY=

# ── searcher runtime tuning ───────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=20
PDF_MAX_MB=50
DOWNLOAD_DIR=/tmp/searcher_mcp_pdfs
MCP_USER_AGENT="searcher-mcp/1.0 (+https://localhost)"

# ── browser_worker runtime tuning ────────────────────────────────────────────
BROWSER_WORKER_CDP_URL=http://127.0.0.1:9222
BROWSER_WORKER_TIMEOUT_SECONDS=45
BROWSER_WORKER_MAX_DOWNLOAD_MB=100
BROWSER_WORKER_DOWNLOAD_DIR=/tmp/browser_worker_pdfs
BROWSER_WORKER_USER_AGENT="browser-worker/1.0 (+https://localhost)"

# ── URL path prefixes (for multi-user deployments) ───────────────────────────
# Set these when hosting multiple stacks under the same domain.
# Example for user "aev": SEARCHER_ROOT_PATH=/aev/search  BROWSER_ROOT_PATH=/aev/browser
# Leave blank for root deployment (single user, no prefix).
SEARCHER_ROOT_PATH=
BROWSER_ROOT_PATH=

# ── noVNC / VNC access ────────────────────────────────────────────────────────
# Password required to access the remote browser via noVNC (port 6080).
# Set this before deploying. Must be 6-8 characters (x11vnc limit).
VNC_PASSWORD=
