[Unit]
Description=Searcher Browser Worker Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/browser_worker
EnvironmentFile=/opt/browser_worker/.env
ExecStart=/opt/browser_worker/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8010
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
