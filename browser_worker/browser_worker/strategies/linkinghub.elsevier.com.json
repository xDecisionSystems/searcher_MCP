{
  "domain": "linkinghub.elsevier.com",
  "source_url": "https://linkinghub.elsevier.com/retrieve/pii/S138912862400714X",
  "login_detection": {
    "enabled": true,
    "signals": ["sign in", "log in", "institutional access", "purchase access", "access denied", "subscribe", "captcha", "verify you are human", "press & hold", "checking your browser"],
    "auth_domains": ["id.elsevier.com", "login.", "auth.", "shibboleth.", "idp."],
    "threshold": 1
  },
  "captcha_note": "ScienceDirect may show a CAPTCHA. If login_required is returned, open noVNC, solve the CAPTCHA, then retry.",
  "steps": [
    {
      "type": "navigate",
      "url_pattern": "https://linkinghub.elsevier.com/retrieve/pii/",
      "example_url": "https://linkinghub.elsevier.com/retrieve/pii/S138912862400714X"
    },
    {
      "type": "click",
      "selector": "span:has-text('View PDF'), a:has-text('Download PDF'), a.accessButton",
      "element_text": "View PDF"
    },
    {
      "type": "wait_for_pdf_response",
      "url_pattern": "https://www.sciencedirect.com/science/article/pii/",
      "example_url": "https://www.sciencedirect.com/science/article/pii/S138912862400714X/pdfft"
    }
  ]
}
